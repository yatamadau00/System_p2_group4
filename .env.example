# Google Maps JavaScript API キー
# https://console.cloud.google.com/ で「Maps JavaScript API」を有効化して取得します。
# このファイルを .env にコピーして値を設定してください。
# キーが未設定でもアプリは静かなフォールバック地図で起動します。
VITE_GOOGLE_MAPS_API_KEY=

# Supabase（全員でことづてを共有する場合のみ設定。未設定なら端末内保存）
# Supabase の Project Settings > API から取得。
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
